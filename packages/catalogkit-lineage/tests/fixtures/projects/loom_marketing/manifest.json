      "name": "fct_clicks_by_customer",
      "unique_id": "model.synthetic.fct_clicks_by_customer",
      "compiled_code": "with customers as (\n  select *\n  from dim_customers\n),\nevents as (\n  select\n    cast(event_id as integer) as event_id,\n    cast(customer_id as integer) as customer_id,\n    cast(clicks as integer) as clicks\n  from campaign_events\n)\nselect\n  c.customer_id,\n  c.customer_name,\n  c.customer_tier,\n  sum(e.clicks) as total_clicks\nfrom events e\njoin customers c\n  on e.customer_id = c.customer_id\ngroup by 1, 2, 3\norder by 1",
      "depends_on": {
        "nodes": [
          "source.loom_marketing.dim_customers",
          "seed.loom_marketing.campaign_events"
        ]
      },
