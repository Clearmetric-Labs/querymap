      "resource_type": "model",
      "name": "fct_revenue_by_customer",
      "unique_id": "model.synthetic.fct_revenue_by_customer",
      "compiled_code": "with customers as (\n  select *\n  from dim_customers\n),\norders as (\n  select\n    cast(order_id as integer) as order_id,\n    cast(customer_id as integer) as customer_id,\n    cast(amount as double) as amount\n  from orders\n)\nselect\n  c.customer_id,\n  c.customer_name,\n  c.customer_tier,\n  sum(o.amount) as total_revenue\nfrom orders o\njoin customers c\n  on o.customer_id = c.customer_id\ngroup by 1, 2, 3\norder by 1",
      "depends_on": {
        "nodes": [
          "source.loom_finance.dim_customers",
          "seed.loom_finance.orders"
        ]
      },
